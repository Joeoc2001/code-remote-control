FROM ghcr.io/joeoc2001/build-box:latest

ARG OPENCODE_VERSION
RUN npm install -g opencode-ai@${OPENCODE_VERSION} tsx

RUN mkdir -p /root/.config/opencode
COPY opencode/package.json /root/.config/opencode/package.json

COPY packages/container-metadata-types /opt/crc/packages/container-metadata-types
COPY packages/container-metadata-server /opt/crc/packages/container-metadata-server

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

WORKDIR /workspace

ENTRYPOINT ["/entrypoint.sh"]
 
